{
  "install": "cd backend && npm install",
  "start": "cd backend && npm run start",
  "watch": {
    "install": {
      "include": [
        "^backend/package\\.json$"
      ]
    },
    "restart": {
      "include": [
        "^backend/src/.*\\.ts$",
        "^backend/prisma/.*"
      ]
    },
    "throttle": 1000
  }
}
